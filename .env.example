DATABASE_URL=postgresql://user:password@localhost:5432/bernardbolter
PAYLOAD_SECRET=YOUR_SECRET_HERE
ANTHROPIC_API_KEY=
ART_OFFICIAL_MODEL=claude-sonnet-4-6
# Anthropic prompt caching (on by default). Set false to disable.
# ART_OFFICIAL_PROMPT_CACHE=false
# Cache TTL for cached system/tools prefix: 5m (default) or 1h (better for long cataloguing sessions)
# ART_OFFICIAL_CACHE_TTL=1h
# Log cache_creation / cache_read token counts to the server console (verify caching is working)
# ART_OFFICIAL_LOG_CACHE=true

# Vendure → Payload print inventory sync (POST /api/webhooks/vendure-sale)
# VENDURE_WEBHOOK_SECRET=
